# global options
{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges 100.64.0.0/10
	}
}

(lb_settings) {
	lb_policy round_robin
	lb_retries 100
	lb_try_duration 10s
	lb_try_interval 250ms
}

(passive_health_checks) {
	fail_duration 60s
	max_fails 300
	unhealthy_latency 5s
	unhealthy_request_count 200
}

:{$PORT} {
	log {
		format json
	}

	# ── guest.gaming-loft.de ──
	@guest host guest.gaming-loft.de
	handle @guest {
		# /api/* → guest-backend (strip /api prefix)
		handle_path /api/* {
			reverse_proxy {
				dynamic a {
					name {$GUEST_BACKEND_DOMAIN:guest-backend.railway.internal}
					port {$GUEST_BACKEND_PORT:4000}
					refresh 1s
					dial_timeout 30s
					versions ipv4 ipv6
				}
				import lb_settings
				import passive_health_checks
				header_up Host {upstream_hostport}
			}
		}
		# everything else → guest-frontend
		reverse_proxy {
			dynamic a {
				name {$GUEST_FRONTEND_DOMAIN:gaming-loft.railway.internal}
				port {$GUEST_FRONTEND_PORT:3000}
				refresh 1s
				dial_timeout 30s
				versions ipv4 ipv6
			}
			import lb_settings
			import passive_health_checks
			header_up Host {upstream_hostport}
		}
	}

	# ── gaming-loft.de (main site, default) ──
	# /api/* → main backend (strip /api prefix)
	handle_path {$BACKEND_PATH:/api}/* {
		reverse_proxy {
			dynamic a {
				name {$BACKEND_DOMAIN}
				port {$BACKEND_PORT}
				refresh 1s
				dial_timeout 30s
				versions ipv4 ipv6
			}
			import lb_settings
			import passive_health_checks
			header_up Host {upstream_hostport}
		}
	}

	# everything else → main frontend
	reverse_proxy {
		dynamic a {
			name {$FRONTEND_DOMAIN}
			port {$FRONTEND_PORT}
			refresh 1s
			dial_timeout 30s
			versions ipv4 ipv6
		}
		import lb_settings
		import passive_health_checks
		header_up Host {upstream_hostport}
	}
}
